{
  "manifest_version": 3,
  "name": "Paper Organizer — Save PDF",
  "description": "Download and name scientific articles using the Paper Organizer format.",
  "version": "1.0.0",
  "permissions": ["activeTab", "downloads", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save article PDF"
  },
  "background": {
    "service_worker": "background.js"
  }
}
