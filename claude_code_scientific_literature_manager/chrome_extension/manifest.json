{
  "manifest_version": 3,
  "name": "Scientific Literature Manager Downloader",
  "description": "Download the current article or PDF with a clean literature-manager filename.",
  "version": "0.1.0",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save article PDF"
  },
  "background": {
    "service_worker": "background.js"
  }
}
